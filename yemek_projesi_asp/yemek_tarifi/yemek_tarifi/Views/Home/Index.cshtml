@model List<yemek_tarifi.Models.Yemek>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🍲 Kayıtlı Yemekler</h2>
        <a href="/Yonetim/Yeni" class="btn btn-primary">Yeni Tarif Ekle</a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var yemek in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@yemek.FotografUrl" class="card-img-top" alt="Yemek" style="height: 200px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title text-primary fw-bold">@yemek.YemekAdi</h5>
                            <p class="card-text text-muted">
                                @(yemek.TarifDetay?.Length > 100 ? yemek.TarifDetay.Substring(0, 100) + "..." : yemek.TarifDetay)
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 d-flex gap-2 pb-3">
                            <a href="/Home/Detay/@yemek.Id" class="btn btn-sm btn-outline-primary flex-grow-1">Tarifi Oku</a>
    
                            <a href="/Yonetim/Sil/@yemek.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('@yemek.YemekAdi tarifini silmek istediğinize emin misiniz?');">
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">Sistemde henüz yemek bulunmuyor.</div>
        }
    </div>
</div>